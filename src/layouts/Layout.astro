---
import '../styles/global.css';
import { ChatWidget } from '../components/ChatWidget';

interface Props {
	title?: string;
	description?: string;
	noindex?: boolean;
}

const { 
	title = "Foundly Agencja - Strony WWW, Kampanie Ads, SEO dla Firm", 
	description = "Nowoczesne, szybkie strony internetowe z wbudowanym systemem pozyskiwania klientów z Google i Meta Ads. Wersja Startowa do kampanii gotowa w 48h. Zobacz cennik.",
	noindex = false
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, "https://foundly.pl").href;
const ogImageUrl = "https://foundly.pl/og-image.png";
const isProd = import.meta.env.PROD;

const schemaData = {
	"@context": "https://schema.org",
	"@type": "ProfessionalService",
	"name": "Foundly Agencja",
	"url": "https://foundly.pl",
	"logo": "https://foundly.pl/og-image.png",
	"image": "https://foundly.pl/og-image.png",
	"description": "Nowoczesne strony internetowe w abonamencie, pozycjonowanie SEO oraz płatne kampanie Google Ads dla małych i średnich firm. Wersja Startowa w 48h.",
	"telephone": "+48786429360",
	"email": "kontakt@foundly.pl",
	"priceRange": "99 PLN - 990 PLN/msc",
	"address": {
		"@type": "PostalAddress",
		"addressCountry": "PL"
	},
	"areaServed": "PL",
	"knowsAbout": [
		"Strony internetowe w abonamencie",
		"Pozycjonowanie SEO",
		"Kampanie Google Ads",
		"Meta Ads",
		"Projektowanie stron WWW",
		"Marketing dla małych firm"
	],
	"offers": [
		{
			"@type": "Offer",
			"name": "Abonament Start",
			"price": "99",
			"priceCurrency": "PLN",
			"description": "Strona One-Page + SEO Lokalne + Wizytówka Google Maps"
		},
		{
			"@type": "Offer",
			"name": "Abonament Growth",
			"price": "390",
			"priceCurrency": "PLN",
			"description": "Rozbudowana strona firmowa do 5 podstron + SEO"
		},
		{
			"@type": "Offer",
			"name": "Business Pro",
			"price": "690",
			"priceCurrency": "PLN",
			"description": "Witryna WordPress + Prowadzenie Kampanii Google Ads"
		}
	]
};
---

<!DOCTYPE html>
<html lang="pl" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="canonical" href={canonicalUrl} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="theme-color" content="#050505" />

		{noindex && <meta name="robots" content="noindex, nofollow" />}

		<!-- Open Graph / Facebook / LinkedIn / Messenger / iMessage / Slack -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:site_name" content="Foundly Agencja" />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:secure_url" content={ogImageUrl} />
		<meta property="og:image:type" content="image/png" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="Foundly Agencja - Strony WWW & Pozyskiwanie Klientów" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalUrl} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content="Foundly Agencja - Strony WWW & Pozyskiwanie Klientów" />

		<!-- Optimized Google Fonts Preconnect & Display Swap -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,700;0,800;1,800&display=swap" rel="stylesheet" />

		<!-- Schema.org JSON-LD Structured Data for AI & Search Engines -->
		<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

		<!-- Asynchronous Performance-First Loading for GTM & Cookiebot -->
		<script is:inline>
			(function loadThirdPartyScripts() {
				var loaded = false;
				function init() {
					if (loaded) return;
					loaded = true;

					// Google Tag Manager
					(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
					new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
					j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
					'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
					})(window,document,'script','dataLayer','GTM-PZG3VR7G');

					// Cookiebot (prod only)
					if (window.location.hostname !== 'localhost') {
						var cb = document.createElement('script');
						cb.id = 'Cookiebot';
						cb.src = 'https://consent.cookiebot.com/uc.js';
						cb.setAttribute('data-cbid', 'e661a291-f3e8-4f26-b9df-1fbd8c1ad5c2');
						cb.setAttribute('data-blockingmode', 'auto');
						cb.type = 'text/javascript';
						document.head.appendChild(cb);
					}
				}

				var events = ['pointerdown', 'scroll', 'touchstart', 'mousemove', 'keydown'];
				events.forEach(function(e) {
					window.addEventListener(e, init, { passive: true, once: true });
				});

				if ('requestIdleCallback' in window) {
					requestIdleCallback(function() {
						setTimeout(init, 3000);
					});
				} else {
					setTimeout(init, 3000);
				}
			})();
		</script>
	</head>
	<body class="bg-[#050505] text-white antialiased selection:bg-indigo-500 selection:text-white font-['Plus_Jakarta_Sans',sans-serif]">
		<!-- Google Tag Manager (noscript) -->
		<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PZG3VR7G"
		height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
		<!-- End Google Tag Manager (noscript) -->

		<slot />

		<!-- Global Czat Widget dla Odwiedzających -->
		<ChatWidget client:idle />
	</body>
</html>
