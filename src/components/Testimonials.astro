---
const reviews = [
  {
    quote: "Strona powstała w 48h i od pierwszego dnia zaczęła przynosić zapytania o montaż mebli kuchennych. Wybór pakietu z pozycjonowaniem to była najlepsza decyzja.",
    author: "Marek W.",
    role: "Stolarz Meble na Wymiar",
    stars: "★★★★★"
  },
  {
    quote: "Próbowałem z dwiema agencjami i zapłaciłem krocie za stronę, która stała pusta. W Foundly zrobili stronę w 2 dni i od razu włączyli Google Ads. Telefony dzwonią codziennie.",
    author: "Tomasz K.",
    role: "Firma Budowlana & Remonty",
    stars: "★★★★★"
  },
  {
    quote: "Profesjonalnie i bez ściemy. Cennik był jasny od samego początku, żadnych ukrytych opłat po wdrożeniu. Pacjenci bardzo chwalą wygląd i łatwość rezerwacji.",
    author: "Anna K.",
    role: "Gabinet Psychoterapii",
    stars: "★★★★★"
  }
];
---

<section class="py-28 bg-[#080808] relative border-t border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-20">
      <div class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-indigo-400 mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-indigo-500"></span>
        <span>06. Opinie Klientów</span>
      </div>
      <h2 class="text-4xl sm:text-6xl font-black uppercase italic tracking-tighter text-white leading-none">
        Co mówią przedsiębiorcy. <br />
        <span class="text-white/40">Średnia ocen 4.9 / 5.0</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {reviews.map((rev) => (
        <div class="p-8 rounded-[2.5rem] bg-white/[0.02] border border-white/5 flex flex-col justify-between hover:border-white/20 transition-all">
          <div>
            <div class="text-amber-400 text-sm tracking-widest mb-6 font-black">{rev.stars}</div>
            <p class="text-sm text-white/80 leading-relaxed font-medium mb-8 italic">
              „{rev.quote}”
            </p>
          </div>

          <div class="flex items-center gap-4 pt-6 border-t border-white/5">
            <div class="w-10 h-10 rounded-full bg-gradient-to-tr from-indigo-500 to-purple-600 flex items-center justify-center font-black text-white text-xs">
              {rev.author.substring(0, 2)}
            </div>
            <div>
              <div class="text-sm font-black text-white italic">{rev.author}</div>
              <div class="text-[11px] font-bold uppercase tracking-wider text-white/40">{rev.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
