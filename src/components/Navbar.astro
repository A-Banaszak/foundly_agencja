---

<header class="fixed top-0 left-0 right-0 z-50 px-2 sm:px-4 py-2.5 sm:py-4 transition-all duration-300">
  <div class="max-w-7xl mx-auto">
    <nav class="glass-card rounded-full sm:rounded-full px-4 sm:px-6 py-2.5 sm:py-3 flex items-center justify-between border border-white/10 bg-[#050505]/95 backdrop-blur-xl shadow-2xl relative z-50">
      
      {/* Brand Logo - AGENCJA visible on mobile too */}
      <a href="/" class="flex items-center gap-1.5 sm:gap-2.5 group shrink-0">
        <span class="text-base sm:text-xl font-black tracking-tighter uppercase italic text-white flex items-center">
          Foundly<span class="text-indigo-500 font-bold not-italic">.</span>
          <span class="inline-block text-[9px] sm:text-[10px] not-italic ml-1.5 sm:ml-2.5 px-2 sm:px-2.5 py-0.5 rounded-full bg-indigo-500/10 text-indigo-400 border border-indigo-500/25 font-black tracking-widest uppercase">
            AGENCJA
          </span>
        </span>
      </a>

      {/* Desktop Navigation Links */}
      <ul class="hidden md:flex items-center gap-6 lg:gap-8 text-xs font-bold uppercase tracking-wider text-white/70">
        <li><a href="/" class="hover:text-white transition-colors">Start</a></li>
        
        <li class="relative group/dd">
          <a href="/uslugi" class="hover:text-white transition-colors flex items-center gap-1 py-1">
            <span>Usługi</span>
            <span class="text-[10px] text-indigo-400 group-hover/dd:rotate-180 transition-transform">▼</span>
          </a>
          <div class="absolute top-full left-0 pt-3 hidden group-hover/dd:block w-72 z-50">
            <div class="p-3 rounded-2xl bg-[#080808]/95 border border-white/10 backdrop-blur-2xl shadow-2xl space-y-1">
              <a href="/uslugi/strony-www" class="block p-3 rounded-xl hover:bg-white/5 transition-colors group/item">
                <div class="text-xs font-black text-white uppercase italic group-hover/item:text-indigo-400 transition-colors">Strony Internetowe</div>
                <div class="text-[10px] text-white/40 font-medium normal-case">Wersja Startowa do kampanii w 48h</div>
              </a>
              <a href="/uslugi/seo" class="block p-3 rounded-xl hover:bg-white/5 transition-colors group/item">
                <div class="text-xs font-black text-white uppercase italic group-hover/item:text-indigo-400 transition-colors">Pozycjonowanie SEO</div>
                <div class="text-[10px] text-white/40 font-medium normal-case">Widoczność w Google & Wizytówka Maps</div>
              </a>
              <a href="/uslugi/kampanie-ads" class="block p-3 rounded-xl hover:bg-white/5 transition-colors group/item">
                <div class="text-xs font-black text-white uppercase italic group-hover/item:text-indigo-400 transition-colors">Płatne Kampanie Reklamowe</div>
                <div class="text-[10px] text-white/40 font-medium normal-case">Google Ads & Meta Ads dla małych firm</div>
              </a>
              <a href="/uslugi/abonament-growth" class="block p-3 rounded-xl hover:bg-gradient-to-r hover:from-indigo-950/40 hover:to-purple-950/40 border border-indigo-500/30 transition-colors group/item">
                <div class="text-xs font-black text-indigo-300 uppercase italic flex items-center justify-between">
                  <span>Subskrypcja All-In-One</span>
                  <span class="text-[9px] px-1.5 py-0.5 rounded bg-indigo-500 text-white font-bold">HOT</span>
                </div>
                <div class="text-[10px] text-white/50 font-medium normal-case">Strona WWW + Marketing w 1 opłacie abonamentowej</div>
              </a>
            </div>
          </div>
        </li>

        <li><a href="/o-nas" class="hover:text-white transition-colors">O nas</a></li>
        <li><a href="/wiedza" class="hover:text-white transition-colors">Wiedza</a></li>
        <li><a href="/kontakt" class="hover:text-white transition-colors">Kontakt</a></li>
      </ul>

      {/* Desktop CTA Button */}
      <div class="hidden md:flex items-center gap-3 shrink-0">
        <a href="/kontakt" class="relative group">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-indigo-500 to-purple-600 rounded-full blur opacity-60 group-hover:opacity-100 transition duration-300"></div>
          <button class="relative px-5 py-2.5 rounded-full bg-white text-black font-black text-xs uppercase tracking-wider transition-all duration-300 hover:bg-zinc-100 flex items-center gap-1.5 cursor-pointer">
            <span>Darmowa wycena</span>
            <svg class="w-3.5 h-3.5 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>
        </a>
      </div>

      {/* Mobile Hamburger Toggle Button */}
      <button 
        id="mobile-menu-toggle"
        type="button" 
        aria-label="Otwórz menu"
        class="md:hidden flex items-center justify-center p-2 rounded-full bg-white/10 text-white hover:bg-white/20 transition-colors focus:outline-none border border-white/10 cursor-pointer shrink-0"
      >
        <svg id="icon-hamburger" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </nav>

    {/* Mobile Menu Drawer Container */}
    <div 
      id="mobile-menu" 
      class="hidden md:hidden mt-2 p-5 rounded-3xl bg-[#09090e]/95 border border-white/15 backdrop-blur-2xl shadow-2xl space-y-4 animate-in fade-in slide-in-from-top-2 duration-200"
    >
      <div class="space-y-1">
        <a href="/" class="block px-4 py-2.5 rounded-xl text-sm font-bold uppercase tracking-wider text-white hover:bg-white/5 transition-colors">
          Start
        </a>
        
        <div class="px-4 py-2 text-[11px] font-black uppercase tracking-widest text-indigo-400">
          Usługi & Oferta:
        </div>
        
        <a href="/uslugi/strony-www" class="block px-6 py-2 rounded-xl text-xs font-bold text-white/80 hover:text-white hover:bg-white/5 transition-colors">
          • Strony Internetowe w 48h
        </a>
        <a href="/uslugi/seo" class="block px-6 py-2 rounded-xl text-xs font-bold text-white/80 hover:text-white hover:bg-white/5 transition-colors">
          • Pozycjonowanie SEO & Maps
        </a>
        <a href="/uslugi/kampanie-ads" class="block px-6 py-2 rounded-xl text-xs font-bold text-white/80 hover:text-white hover:bg-white/5 transition-colors">
          • Kampanie Google Ads & Meta Ads
        </a>
        <a href="/uslugi/abonament-growth" class="block px-6 py-2 rounded-xl text-xs font-bold text-indigo-300 hover:text-white hover:bg-indigo-950/40 border border-indigo-500/30 transition-colors">
          ★ Subskrypcja All-In-One (HOT)
        </a>
      </div>

      <div class="border-t border-white/10 pt-3 space-y-1">
        <a href="/o-nas" class="block px-4 py-2.5 rounded-xl text-sm font-bold uppercase tracking-wider text-white hover:bg-white/5 transition-colors">
          O nas
        </a>
        <a href="/wiedza" class="block px-4 py-2.5 rounded-xl text-sm font-bold uppercase tracking-wider text-white hover:bg-white/5 transition-colors">
          Wiedza
        </a>
        <a href="/kontakt" class="block px-4 py-2.5 rounded-xl text-sm font-bold uppercase tracking-wider text-white hover:bg-white/5 transition-colors">
          Kontakt
        </a>
      </div>

      <div class="pt-2 border-t border-white/10">
        <a href="/kontakt" class="block w-full">
          <button class="w-full py-3.5 rounded-2xl bg-white text-black font-black text-xs uppercase tracking-widest hover:bg-zinc-200 transition-colors shadow-xl flex items-center justify-center gap-2 cursor-pointer">
            <span>Darmowa wycena</span>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>
        </a>
      </div>
    </div>

  </div>
</header>

<script is:inline>
  (function setupMobileMenu() {
    function init() {
      const toggleBtn = document.getElementById('mobile-menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const iconHamburger = document.getElementById('icon-hamburger');
      const iconClose = document.getElementById('icon-close');

      if (!toggleBtn || !mobileMenu || !iconHamburger || !iconClose) return;
      if (toggleBtn.getAttribute('data-bound') === 'true') return;
      toggleBtn.setAttribute('data-bound', 'true');

      toggleBtn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var isHidden = mobileMenu.classList.contains('hidden');
        if (isHidden) {
          mobileMenu.classList.remove('hidden');
          iconHamburger.classList.add('hidden');
          iconClose.classList.remove('hidden');
        } else {
          mobileMenu.classList.add('hidden');
          iconHamburger.classList.remove('hidden');
          iconClose.classList.add('hidden');
        }
      });

      var links = mobileMenu.querySelectorAll('a');
      links.forEach(function(link) {
        link.addEventListener('click', function() {
          mobileMenu.classList.add('hidden');
          iconHamburger.classList.remove('hidden');
          iconClose.classList.add('hidden');
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
