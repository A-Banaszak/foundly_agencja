<header class="fixed top-0 left-0 right-0 z-50 px-4 py-4 transition-all duration-300">
  <div class="max-w-7xl mx-auto">
    <nav class="glass-card rounded-full px-6 py-3 flex items-center justify-between border border-white/10 bg-[#050505]/70 backdrop-blur-xl shadow-2xl">
      <!-- Logo -->
      <a href="#" class="flex items-center gap-2 group">
        <div class="w-8 h-8 rounded-xl bg-gradient-to-tr from-indigo-600 via-indigo-500 to-purple-500 flex items-center justify-center font-black text-white text-lg shadow-[0_0_20px_rgba(99,102,241,0.5)] group-hover:scale-105 transition-transform">
          F
        </div>
        <span class="text-xl font-black tracking-tighter uppercase italic text-white flex items-center">
          Foundly<span class="text-indigo-500 font-bold not-italic">.</span><span class="text-[10px] not-italic ml-2 px-2 py-0.5 rounded-full bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 font-bold tracking-widest">AGENCJA</span>
        </span>
      </a>

      <!-- Desktop Nav Links -->
      <ul class="hidden md:flex items-center gap-8 text-xs font-bold uppercase tracking-wider text-white/70">
        <li><a href="#dlaczego-my" class="hover:text-white transition-colors">Dlaczego My</a></li>
        <li><a href="#cennik" class="hover:text-white transition-colors">Cennik</a></li>
        <li><a href="#kalkulator" class="hover:text-indigo-400 transition-colors flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"></span>Kalkulator</a></li>
        <li><a href="#branze" class="hover:text-white transition-colors">Branże</a></li>
        <li><a href="#proces" class="hover:text-white transition-colors">Proces</a></li>
        <li><a href="#realizacje" class="hover:text-white transition-colors">Realizacje</a></li>
        <li><a href="#faq" class="hover:text-white transition-colors">FAQ</a></li>
      </ul>

      <!-- CTA Button -->
      <div class="flex items-center gap-3">
        <a href="#kalkulator" class="relative group">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-indigo-500 to-purple-600 rounded-full blur opacity-60 group-hover:opacity-100 transition duration-300"></div>
          <button class="relative px-5 py-2.5 rounded-full bg-white text-black font-black text-xs uppercase tracking-wider transition-all duration-300 hover:bg-zinc-100 flex items-center gap-2">
            <span>Darmowa wycena</span>
            <svg class="w-3.5 h-3.5 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>
        </a>
      </div>
    </nav>
  </div>
</header>
