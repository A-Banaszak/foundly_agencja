---
---

<header class="fixed top-0 left-0 right-0 z-50 px-2 sm:px-4 py-2.5 sm:py-4 transition-all duration-300">
  <div class="max-w-7xl mx-auto">
    <nav class="glass-card rounded-full px-3.5 sm:px-6 py-2 sm:py-3 flex items-center justify-between border border-white/10 bg-[#050505]/90 backdrop-blur-xl shadow-2xl relative z-50">
      <a href="/" class="flex items-center gap-1.5 sm:gap-2.5 group shrink-0">
        <span class="text-base sm:text-xl font-black tracking-tighter uppercase italic text-white flex items-center">
          Foundly<span class="text-indigo-500 font-bold not-italic">.</span>
          <span class="hidden sm:inline-block text-[9px] sm:text-[10px] not-italic ml-1.5 sm:ml-2.5 px-2 sm:px-2.5 py-0.5 rounded-full bg-indigo-500/10 text-indigo-400 border border-indigo-500/25 font-black tracking-widest uppercase">
            AGENCJA
          </span>
        </span>
      </a>

      <ul class="hidden md:flex items-center gap-8 text-xs font-bold uppercase tracking-wider text-white/70">
        <li><a href="/" class="hover:text-white transition-colors">Start</a></li>
        
        <li class="relative group/dd">
          <a href="/uslugi" class="hover:text-white transition-colors flex items-center gap-1 py-1">
            <span>Usługi</span>
            <span class="text-[10px] text-indigo-400 group-hover/dd:rotate-180 transition-transform">▼</span>
          </a>
          <div class="absolute top-full left-0 pt-3 hidden group-hover/dd:block w-72 z-50">
            <div class="p-3 rounded-2xl bg-[#080808]/95 border border-white/10 backdrop-blur-2xl shadow-2xl space-y-1">
              <a href="/uslugi/strony-www" class="block p-3 rounded-xl hover:bg-white/5 transition-colors group/item">
                <div class="text-xs font-black text-white uppercase italic group-hover/item:text-indigo-400 transition-colors">Strony Internetowe</div>
                <div class="text-[10px] text-white/40 font-medium normal-case">Wersja Startowa do kampanii w 48h</div>
              </a>
              <a href="/uslugi/seo" class="block p-3 rounded-xl hover:bg-white/5 transition-colors group/item">
                <div class="text-xs font-black text-white uppercase italic group-hover/item:text-indigo-400 transition-colors">Pozycjonowanie SEO</div>
                <div class="text-[10px] text-white/40 font-medium normal-case">Widoczność w Google & Wizytówka Maps</div>
              </a>
              <a href="/uslugi/kampanie-ads" class="block p-3 rounded-xl hover:bg-white/5 transition-colors group/item">
                <div class="text-xs font-black text-white uppercase italic group-hover/item:text-indigo-400 transition-colors">Płatne Kampanie Reklamowe</div>
                <div class="text-[10px] text-white/40 font-medium normal-case">Google Ads & Meta Ads dla małych firm</div>
              </a>
              <a href="/uslugi/abonament-growth" class="block p-3 rounded-xl hover:bg-gradient-to-r hover:from-indigo-950/40 hover:to-purple-950/40 border border-indigo-500/30 transition-colors group/item">
                <div class="text-xs font-black text-indigo-300 uppercase italic flex items-center justify-between">
                  <span>Subskrypcja All-In-One</span>
                  <span class="text-[9px] px-1.5 py-0.5 rounded bg-indigo-500 text-white font-bold">0 PLN</span>
                </div>
                <div class="text-[10px] text-white/50 font-medium normal-case">Strona za 0 zł + Marketing w 1 opłacie</div>
              </a>
            </div>
          </div>
        </li>

        <li><a href="/o-nas" class="hover:text-white transition-colors">O nas</a></li>
        <li><a href="/kontakt" class="hover:text-white transition-colors">Kontakt</a></li>
      </ul>

      <div class="flex items-center gap-2 sm:gap-3 shrink-0">
        <a href="/kontakt" class="relative group">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-indigo-500 to-purple-600 rounded-full blur opacity-60 group-hover:opacity-100 transition duration-300"></div>
          <button class="relative px-3 sm:px-5 py-1.5 sm:py-2.5 rounded-full bg-white text-black font-black text-[10px] sm:text-xs uppercase tracking-wider transition-all duration-300 hover:bg-zinc-100 flex items-center gap-1.5">
            <span>Darmowa wycena</span>
            <svg class="w-3 h-3 sm:w-3.5 sm:h-3.5 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>
        </a>

        <!-- Hamburger Button on Mobile -->
        <button id="mobile-menu-btn" aria-label="Menu" class="md:hidden w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white hover:bg-white/10 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile Drawer Menu -->
    <div id="mobile-menu" class="hidden fixed inset-0 z-40 bg-[#050505]/95 backdrop-blur-2xl px-6 pt-28 pb-10 flex flex-col justify-between border-b border-white/10">
      <div class="space-y-6">
        <div class="text-xs font-black uppercase tracking-widest text-indigo-400">Nawigacja</div>
        <ul class="space-y-4 text-base font-black uppercase italic tracking-tight text-white">
          <li><a href="/" class="block hover:text-indigo-400 transition-colors mobile-link">Start</a></li>
          <li><a href="/uslugi/strony-www" class="block hover:text-indigo-400 transition-colors mobile-link">Strony Internetowe</a></li>
          <li><a href="/uslugi/seo" class="block hover:text-indigo-400 transition-colors mobile-link">Pozycjonowanie SEO</a></li>
          <li><a href="/uslugi/kampanie-ads" class="block hover:text-indigo-400 transition-colors mobile-link">Kampanie Ads</a></li>
          <li><a href="/uslugi/abonament-growth" class="block text-indigo-300 hover:text-indigo-400 transition-colors mobile-link">Abonament 0 PLN</a></li>
          <li><a href="/o-nas" class="block hover:text-indigo-400 transition-colors mobile-link">O Nas</a></li>
          <li><a href="/kontakt" class="block hover:text-indigo-400 transition-colors mobile-link">Kontakt</a></li>
        </ul>
      </div>

      <div class="pt-6 border-t border-white/10">
        <a href="/kontakt" class="w-full">
          <button class="w-full h-12 rounded-2xl bg-gradient-to-r from-indigo-500 to-purple-600 text-white font-black text-xs uppercase tracking-widest shadow-xl">
            Darmowa Wycena Online
          </button>
        </a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const links = document.querySelectorAll('.mobile-link');

  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
    links.forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
      });
    });
  }
</script>
