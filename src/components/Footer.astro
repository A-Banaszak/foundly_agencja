<footer class="bg-[#030303] text-white/40 pt-20 pb-12 border-t border-white/10 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      <!-- Col 1: Brand -->
      <div class="space-y-4 md:col-span-2">
        <a href="#" class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-xl bg-gradient-to-tr from-indigo-600/30 to-purple-600/30 border border-indigo-500/40 flex items-center justify-center text-indigo-400">
            <svg 
              xmlns="http://www.w3.org/2000/svg" 
              width="22" 
              height="22" 
              viewBox="0 0 24 24" 
              fill="none" 
              stroke="currentColor" 
              stroke-width="2" 
              stroke-linecap="round" 
              stroke-linejoin="round" 
              class="text-indigo-400"
            >
              <path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z" />
              <path d="M20 2v4" />
              <path d="M22 4h-4" />
              <circle cx="4" cy="20" r="2" />
            </svg>
          </div>
          <span class="text-2xl font-black tracking-tighter uppercase italic text-white flex items-center">
            Foundly<span class="text-indigo-500 font-bold not-italic">.</span>
            <span class="text-xs not-italic ml-2.5 px-2.5 py-0.5 rounded-full bg-indigo-500/10 text-indigo-400 border border-indigo-500/25 font-black tracking-widest uppercase">
              AGENCJA
            </span>
          </span>
        </a>
        <p class="text-xs text-white/50 max-w-sm font-medium leading-relaxed">
          Tworzymy szybkie, konwertujące strony internetowe zintegrowane z systemem pozyskiwania klientów z Google (SEO + Google Ads). Realizacja od 48h.
        </p>
        <div class="text-xs font-bold text-white/70">
          📍 Polska • Wdrożenia dla firm w całym kraju
        </div>
      </div>

      <!-- Col 2: Navigation -->
      <div>
        <h4 class="text-xs font-black uppercase tracking-widest text-white mb-4 italic">Nawigacja</h4>
        <ul class="space-y-2.5 text-xs font-bold uppercase tracking-wider text-white/60">
          <li><a href="#dlaczego-my" class="hover:text-indigo-400 transition-colors">Dlaczego My</a></li>
          <li><a href="#cennik" class="hover:text-indigo-400 transition-colors">Cennik Pakiety</a></li>
          <li><a href="#kalkulator" class="hover:text-indigo-400 transition-colors">Kalkulator Wyceny</a></li>
          <li><a href="#branze" class="hover:text-indigo-400 transition-colors">Dedykowane Branże</a></li>
          <li><a href="#realizacje" class="hover:text-indigo-400 transition-colors">Realizacje</a></li>
        </ul>
      </div>

      <!-- Col 3: Legal & Contact -->
      <div>
        <h4 class="text-xs font-black uppercase tracking-widest text-white mb-4 italic">Kontakt</h4>
        <ul class="space-y-2.5 text-xs font-medium text-white/60">
          <li>E-mail: <a href="mailto:kontakt@foundly.pl" class="text-white font-bold hover:text-indigo-400">kontakt@foundly.pl</a></li>
          <li>Wdrożenia: 48 godzin</li>
          <li>Gwarancja Satysfakcji</li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between text-[11px] font-medium text-white/30 gap-4">
      <div>© {new Date().getFullYear()} Foundly Agencja. Wszystkie prawa zastrzeżone.</div>
      <div class="flex gap-6">
        <a href="#" class="hover:text-white transition-colors">Polityka Prywatności</a>
        <a href="#" class="hover:text-white transition-colors">Regulamin Usług</a>
      </div>
    </div>
  </div>
</footer>
