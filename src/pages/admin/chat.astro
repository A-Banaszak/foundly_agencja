---
import Layout from '../../layouts/Layout.astro';
import { ChatAdmin } from '../../components/ChatAdmin';
---

<Layout title="Panel Czata — Foundly Agencja" noindex={true}>
	<main class="min-h-screen p-6 bg-[#050505]">
		<div class="max-w-6xl mx-auto mb-6 flex justify-between items-center">
			<a href="/" class="text-xs text-white/50 hover:text-white transition-all">← Wróć do strony głównej</a>
			<span class="text-xs font-mono text-indigo-400">Foundly Chat Admin v1.0</span>
		</div>
		<ChatAdmin client:only="react" />
	</main>
</Layout>
