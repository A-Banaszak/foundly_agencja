---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Akceptacja Oferty — Foundly Agencja">
  <main class="pt-32 pb-24 relative overflow-hidden min-h-screen flex items-center justify-center">
    {/* Glow Background Elements */}
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-indigo-600/15 rounded-full blur-[140px] pointer-events-none -z-10 animate-pulse-glow"></div>
    <div class="absolute top-1/3 left-1/4 w-[400px] h-[400px] bg-purple-600/10 rounded-full blur-[120px] pointer-events-none -z-10"></div>

    <div class="max-w-2xl w-full mx-auto px-4 sm:px-6">
      <div class="glass-card p-8 sm:p-12 rounded-[2.5rem] border border-white/10 bg-[#08080c]/95 md:backdrop-blur-xl shadow-2xl relative">
        
        {/* Header */}
        <div class="text-center mb-8">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-indigo-500/10 border border-indigo-500/25 text-[10px] sm:text-xs font-bold uppercase tracking-widest text-indigo-400 mb-4">
            <span class="w-2 h-2 rounded-full bg-indigo-500 animate-ping"></span>
            <span>Potwierdzenie & Kontakt</span>
          </div>

          <h1 class="text-3xl sm:text-4xl font-black uppercase italic tracking-tighter text-white mb-3">
            Akceptacja Oferty <br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-400">
              Foundly Agencja
            </span>
          </h1>
          <p class="text-sm text-white/60 font-medium">
            Wypełnij poniższe pole, a oddzwonimy w ciągu maksymalnie 30 minut, aby omówić szczegóły i uruchomić prace.
          </p>
        </div>

        {/* Podsumowanie Wybranej Oferty */}
        <div id="offerSummaryBox" class="p-6 rounded-2xl bg-white/[0.03] border border-indigo-500/30 mb-8 space-y-3">
          <div class="flex items-center justify-between text-xs text-white/50 border-b border-white/5 pb-2">
            <span>Dla kogo:</span>
            <strong id="summaryClient" class="text-white font-bold">-</strong>
          </div>
          <div class="flex items-center justify-between text-xs text-white/50 border-b border-white/5 pb-2">
            <span>Adres email:</span>
            <strong id="summaryEmail" class="text-indigo-300 font-bold">-</strong>
          </div>
          <div class="flex items-center justify-between text-xs text-white/50 pb-1">
            <span>Dotyczy projektu:</span>
            <strong id="summaryOffer" class="text-white font-bold">-</strong>
          </div>
        </div>

        {/* Formularz Pozostawienia Telefonu & Wyboru Wariantu */}
        <form id="acceptanceForm" class="space-y-5">
          <input type="hidden" id="inputClient" name="client" />
          <input type="hidden" id="inputEmail" name="email" />
          <input type="hidden" id="inputOffer" name="offer" />

          <div>
            <label for="variantSelect" class="block text-xs font-bold uppercase tracking-wider text-white/80 mb-2">
              Wybierz Wariant Współpracy *
            </label>
            <select 
              id="variantSelect" 
              name="variant" 
              class="w-full px-5 py-4 rounded-2xl bg-black/60 border-2 border-indigo-500/50 text-white font-bold focus:border-indigo-400 focus:outline-none focus:ring-4 focus:ring-indigo-500/20 transition-all text-sm appearance-none cursor-pointer"
            >
              <option value="Wariant 1: Jednorazowe Wdrożenie (1 900 PLN)">Wariant 1: Jednorazowe Wdrożenie (1 900 PLN)</option>
              <option value="Wariant 2: Start Growth - Strona + Lokalne SEO (390 PLN / msc)">Wariant 2: Start Growth (390 PLN / msc)</option>
              <option value="Wariant 3: Business Pro Restaurant - Strona + SEO + Social Media (690 PLN / msc)" selected>Wariant 3: Business Pro Restaurant (690 PLN / msc)</option>
            </select>
          </div>

          <div>
            <label for="phoneInput" class="block text-xs font-bold uppercase tracking-wider text-white/80 mb-2">
              Twój numer telefonu *
            </label>
            <input 
              type="tel" 
              id="phoneInput" 
              name="phone"
              required 
              placeholder="np. 500 600 700" 
              class="w-full px-5 py-4 rounded-2xl bg-black/60 border-2 border-indigo-500/50 text-white font-bold placeholder:text-white/20 focus:border-indigo-400 focus:outline-none focus:ring-4 focus:ring-indigo-500/20 transition-all text-base"
            />
          </div>

          <button 
            type="submit" 
            id="submitBtn"
            class="w-full py-4 px-8 rounded-2xl bg-gradient-to-r from-indigo-500 via-indigo-600 to-purple-600 hover:from-indigo-400 hover:to-purple-500 text-white font-black text-sm uppercase tracking-widest transition-all duration-300 shadow-[0_0_40px_rgba(99,102,241,0.3)] hover:shadow-[0_0_60px_rgba(99,102,241,0.5)] active:scale-[0.98] cursor-pointer flex items-center justify-center gap-2"
          >
            <span>Potwierdzam • Proszę o kontakt telefoniczny</span>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>
        </form>

        {/* Wiadomość Sukcesu */}
        <div id="successBox" class="hidden p-6 rounded-2xl bg-emerald-500/10 border border-emerald-500/40 text-center space-y-2 mt-6">
          <div class="text-emerald-400 font-black text-lg uppercase italic">Dziękujemy! Zgłoszenie zostało wysłane.</div>
          <p class="text-xs text-white/70 font-medium">
            Otrzymaliśmy Twoje potwierdzenie. Skontaktujemy się z Tobą telefonicznie w ciągu kilkunastu minut.
          </p>
        </div>

      </div>
    </div>
  </main>
</Layout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    const client = urlParams.get('client') || 'Klient';
    const email = urlParams.get('email') || '-';
    const offer = urlParams.get('offer') || 'Strona Internetowa';
    const variantParam = urlParams.get('variant') || '';

    // Wypełnij podsumowanie
    document.getElementById('summaryClient').textContent = client;
    document.getElementById('summaryEmail').textContent = email;
    document.getElementById('summaryOffer').textContent = offer;

    // Wypełnij Ukryte Pola
    document.getElementById('inputClient').value = client;
    document.getElementById('inputEmail').value = email;
    document.getElementById('inputOffer').value = offer;

    // Dopasuj domyślny select z URL jeśli przekazano
    const selectEl = document.getElementById('variantSelect');
    if (variantParam && selectEl) {
      for (let option of selectEl.options) {
        if (option.value.toLowerCase().includes(variantParam.toLowerCase()) || variantParam.toLowerCase().includes(option.value.toLowerCase())) {
          option.selected = true;
          break;
        }
      }
    }

    // Wyślij cichy ping na Discord, że klient właśnie otworzył link z oferty!
    fetch('/api/chat.php?action=offer_view', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        client: client,
        email: email,
        offer: offer,
        variant: selectEl ? selectEl.value : variantParam
      })
    }).catch(console.error);

    // Obsługa Formularza
    const form = document.getElementById('acceptanceForm');
    const submitBtn = document.getElementById('submitBtn');
    const successBox = document.getElementById('successBox');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const phone = document.getElementById('phoneInput').value;
      const selectedVariant = selectEl ? selectEl.value : '';

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.querySelector('span').textContent = 'Wysyłanie zgłoszenia...';
      }

      try {
        const res = await fetch('/api/chat.php?action=submit_lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: client,
            email: email !== '-' ? email : '',
            phone: phone,
            offer: offer,
            variant: selectedVariant,
            message: `[AKCEPTACJA OFERTY ONLINE] Oferta: ${offer} | Wariant: ${selectedVariant}`
          })
        });

        if (form) form.style.display = 'none';
        if (successBox) successBox.classList.remove('hidden');
      } catch (err) {
        console.error(err);
        alert('Wystąpił błąd. Prosimy o kontakt pod numerem +48 881 548 644');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.querySelector('span').textContent = 'Potwierdzam • Proszę o kontakt telefoniczny';
        }
      }
    });
  });
</script>
