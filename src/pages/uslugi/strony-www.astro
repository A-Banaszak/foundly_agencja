---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CalculatorWizard from '../../components/CalculatorWizard';
---

<Layout title="Strony Internetowe dla Firm — Foundly Agencja">
	<Navbar />
	<main class="pt-32 pb-24">
		<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="max-w-3xl mb-16">
				<div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-indigo-500/10 border border-indigo-500/30 text-xs font-bold uppercase tracking-widest text-indigo-400 mb-6">
					<span>Usługi • Strony WWW</span>
				</div>
				<h1 class="text-4xl sm:text-6xl lg:text-7xl font-black uppercase italic tracking-tighter text-white leading-none mb-8">
					Nowoczesne strony WWW <br />
					<span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-400">
						gotowe w 48 godzin.
					</span>
				</h1>
				<p class="text-white/60 text-lg leading-relaxed">
					Tworzymy wyjątkowo szybkie, czytelne i zoptymalizowane pod kątem urządzeń mobilnych strony internetowe. Wszystkie witryny piszemy w ultra-lekkiej technologii Astro.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-24">
				<div class="p-8 rounded-[2.5rem] bg-white/[0.02] border border-white/10 flex flex-col justify-between">
					<div>
						<h3 class="text-2xl font-black uppercase italic text-white mb-2">Starter One-Page</h3>
						<div class="text-3xl font-black text-indigo-400 italic mb-6">890 PLN <span class="text-xs font-normal text-white/40">netto</span></div>
						<ul class="space-y-3 text-xs font-medium text-white/70">
							<li>✓ Strona lądowania do 6 sekcji</li>
							<li>✓ Dedykowane teksty branżowe</li>
							<li>✓ Formularz + podpięcie mapy</li>
							<li>✓ Optymalizacja SEO On-Page</li>
						</ul>
					</div>
					<a href="/kontakt" class="mt-8 block text-center py-3 rounded-full bg-white/10 text-white font-bold text-xs uppercase tracking-widest hover:bg-white/20 transition-colors">Zamów Starter</a>
				</div>

				<div class="p-8 rounded-[2.5rem] bg-gradient-to-b from-indigo-950/40 to-black border-2 border-indigo-500 shadow-xl flex flex-col justify-between">
					<div>
						<span class="px-3 py-1 rounded-full bg-indigo-500 text-white text-[9px] font-black uppercase tracking-widest">Najczęściej Wybierana</span>
						<h3 class="text-2xl font-black uppercase italic text-white mt-3 mb-2">Business Multi-Page</h3>
						<div class="text-3xl font-black text-indigo-300 italic mb-6">1490 PLN <span class="text-xs font-normal text-white/40">netto</span></div>
						<ul class="space-y-3 text-xs font-medium text-white">
							<li>✓ Do 5 rozbudowanych podstron</li>
							<li>✓ Dedykowana oferta i realizacje</li>
							<li>✓ Analityka GA4 w cenie</li>
							<li>✓ 2 tury poprawek + opieka 30 dni</li>
						</ul>
					</div>
					<a href="/kontakt" class="mt-8 block text-center py-3 rounded-full bg-white text-black font-black text-xs uppercase tracking-widest hover:bg-zinc-200 transition-colors">Zamów Business</a>
				</div>

				<div class="p-8 rounded-[2.5rem] bg-white/[0.02] border border-white/10 flex flex-col justify-between">
					<div>
						<h3 class="text-2xl font-black uppercase italic text-white mb-2">Sklep E-Commerce</h3>
						<div class="text-3xl font-black text-indigo-400 italic mb-6">od 2990 PLN <span class="text-xs font-normal text-white/40">netto</span></div>
						<ul class="space-y-3 text-xs font-medium text-white/70">
							<li>✓ Sprzedaż online i płatności BLIK</li>
							<li>✓ Integracja kurierów InPost</li>
							<li>✓ Panel zarządzania sklepem</li>
							<li>✓ Wsparcia opiekuna technicznego</li>
						</ul>
					</div>
					<a href="/kontakt" class="mt-8 block text-center py-3 rounded-full bg-white/10 text-white font-bold text-xs uppercase tracking-widest hover:bg-white/20 transition-colors">Wycena Sklepu</a>
				</div>
			</div>

			<CalculatorWizard client:visible />
		</section>
	</main>
	<Footer />
</Layout>
