---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import WebsiteOrderForm from '../../components/forms/WebsiteOrderForm';
import { ArrowRight, Sparkles } from 'lucide-react';
---

<Layout title="Strony Internetowe dla Firm - Foundly Agencja">
	<Navbar />
	<main class="pt-32 pb-24">
		<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="max-w-3xl mb-16">
				<div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-indigo-500/10 border border-indigo-500/30 text-xs font-bold uppercase tracking-widest text-indigo-400 mb-6">
					<span>Usługi • Strony WWW</span>
				</div>
				<h1 class="text-4xl sm:text-6xl lg:text-7xl font-black uppercase italic tracking-tighter text-white leading-none mb-8">
					Nowoczesne strony WWW <br />
					<span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-400">
						z Wersją Startową w 48h.
					</span>
				</h1>
				<p class="text-white/60 text-lg leading-relaxed">
					Tworzymy wyjątkowo szybkie, czytelne i zoptymalizowane pod kątem urządzeń mobilnych strony internetowe w nowoczesnej technologii Astro lub WordPress.
				</p>
			</div>

			{/* Bannerek promujący abonament */}
			<div class="mb-16 p-8 rounded-[2.5rem] bg-gradient-to-r from-indigo-950/40 via-purple-950/20 to-black border border-indigo-500/30 flex flex-col sm:flex-row items-center justify-between gap-6">
				<div>
					<div class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-indigo-300 mb-1">
						<Sparkles class="w-4 h-4" />
						<span>Alternatywny Model Rozliczenia</span>
					</div>
					<h3 class="text-xl font-black uppercase italic text-white">
						Nie chcesz wydawać kilku tysięcy z góry za stronę?
					</h3>
					<p class="text-xs text-white/60 mt-1">
						Skorzystaj z Subskrypcji All-In-One: strona, hosting, SEO i reklamy w 1 opłacie abonamentowej.
					</p>
				</div>
				<a href="/uslugi/abonament-growth" class="shrink-0">
					<button class="px-6 h-12 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white font-bold text-xs uppercase tracking-widest transition-all flex items-center gap-2">
						<span>Sprawdź Abonament</span>
						<ArrowRight class="w-4 h-4" />
					</button>
				</a>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-24">
				<div class="p-8 rounded-[2.5rem] bg-white/[0.02] border border-white/10 flex flex-col justify-between">
					<div>
						<h3 class="text-2xl font-black uppercase italic text-white mb-2">Starter One-Page</h3>
						<div class="text-3xl font-black text-indigo-400 italic mb-6">od 999 PLN</div>
						<ul class="space-y-3 text-xs font-medium text-white/70">
							<li>✓ Szybka strona statyczna (Landing Page)</li>
							<li>✓ Dedykowane teksty branżowe</li>
							<li>✓ Formularz + podpięcie mapy</li>
							<li>✓ Optymalizacja SEO On-Page</li>
						</ul>
					</div>
				</div>

				<div class="p-8 rounded-[2.5rem] bg-gradient-to-b from-indigo-950/40 to-black border-2 border-indigo-500 shadow-xl flex flex-col justify-between">
					<div>
						<span class="px-3 py-1 rounded-full bg-indigo-500 text-white text-[9px] font-black uppercase tracking-widest">Najczęściej Wybierana</span>
						<h3 class="text-2xl font-black uppercase italic text-white mt-3 mb-2">Business Multi-Page</h3>
						<div class="text-3xl font-black text-indigo-300 italic mb-6">od 2 499 PLN</div>
						<ul class="space-y-3 text-xs font-medium text-white">
							<li>✓ System CMS WordPress (opcja samodzielnej edycji)</li>
							<li>✓ Do 5 rozbudowanych podstron</li>
							<li>✓ Analityka GA4 w cenie</li>
							<li>✓ 2 tury poprawek + opieka 30 dni</li>
						</ul>
					</div>
				</div>

				<div class="p-8 rounded-[2.5rem] bg-white/[0.02] border border-white/10 flex flex-col justify-between">
					<div>
						<h3 class="text-2xl font-black uppercase italic text-white mb-2">Sklep E-Commerce</h3>
						<div class="text-3xl font-black text-indigo-400 italic mb-6">od 4 499 PLN</div>
						<ul class="space-y-3 text-xs font-medium text-white/70">
							<li>✓ System WordPress + Sklep WooCommerce</li>
							<li>✓ Płatności online BLIK / Przelewy24 / Karty</li>
							<li>✓ Integracja kurierów InPost</li>
							<li>✓ Panel zarządzania sklepem i zamówieniami</li>
						</ul>
					</div>
				</div>
			</div>

			<WebsiteOrderForm client:visible />
		</section>
	</main>
	<Footer />
</Layout>
