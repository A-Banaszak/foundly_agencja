---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import SeoAuditForm from '../../components/forms/SeoAuditForm';
---

<Layout title="Pozycjonowanie SEO & Google Maps - Foundly Agencja">
	<Navbar />
	<main class="pt-32 pb-24">
		<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="max-w-3xl mb-16">
				<div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-indigo-500/10 border border-indigo-500/30 text-xs font-bold uppercase tracking-widest text-indigo-400 mb-6">
					<span>Lokalne SEO & Google Maps</span>
				</div>
				<h1 class="text-4xl sm:text-6xl font-black uppercase italic tracking-tighter text-white mb-6">
					Bądź pierwszy w Google, <br />
					<span class="text-indigo-400">gdy klient szuka Twoich usług.</span>
				</h1>
				<p class="text-white/60 text-lg leading-relaxed">
					Zwiększamy widoczność Twojej firmy na lokalne frazy kluczowe oraz w Mapach Google. Zero obietnic bez pokrycia - czytelne raporty pozycji co miesiąc.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-24">
				<div class="p-8 rounded-[2.5rem] bg-white/[0.02] border border-white/10 flex flex-col justify-between">
					<div>
						<h3 class="text-xl font-black uppercase italic text-white mb-2">Pozycjonowanie Maps</h3>
						<p class="text-xs text-white/50 mb-6">Wizytówka firmy w mapach - pierwsze miejsce, gdzie szukają lokalni klienci.</p>
						<ul class="space-y-2.5 text-xs font-bold text-white/70">
							<li>✓ Audyt i uzupełnienie wizytówki</li>
							<li>✓ Geolokalizacja usług i obszaru</li>
							<li>✓ Monitorowanie opinii i pozycji</li>
						</ul>
					</div>
				</div>

				<div class="p-8 rounded-[2.5rem] bg-white/[0.02] border border-white/10 flex flex-col justify-between">
					<div>
						<h3 class="text-xl font-black uppercase italic text-white mb-2">SEO Lokalne</h3>
						<p class="text-xs text-white/50 mb-6">Pozycjonowanie na frazy z Twojego miasta (np. stolarz Warszawa).</p>
						<ul class="space-y-2.5 text-xs font-bold text-white/70">
							<li>✓ Analiza słów kluczowych konkurencji</li>
							<li>✓ Optymalizacja treści On-Page</li>
							<li>✓ Budowanie linków lokalnych</li>
						</ul>
					</div>
				</div>

				<div class="p-8 rounded-[2.5rem] bg-white/[0.02] border border-white/10 flex flex-col justify-between">
					<div>
						<h3 class="text-xl font-black uppercase italic text-white mb-2">Stałe Raportowanie Wyników</h3>
						<p class="text-xs text-white/50 mb-6">Co miesiąc przejrzyste podsumowanie pozycji i przyrostu zapytań.</p>
						<ul class="space-y-2.5 text-xs font-bold text-white/70">
							<li>✓ Dostęp do panelu statystyk</li>
							<li>✓ Raport pozycji na frazy</li>
							<li>✓ Podsumowanie ruchu z Google</li>
						</ul>
					</div>
				</div>
			</div>

			<SeoAuditForm client:visible />
		</section>
	</main>
	<Footer />
</Layout>
