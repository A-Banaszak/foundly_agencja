---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CalculatorWizard from '../components/CalculatorWizard';
import FAQ from '../components/FAQ.astro';
---

<Layout title="Kontakt i Darmowa Wycena - Foundly Agencja">
	<Navbar />
	<main class="pt-32 pb-24">
		<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="max-w-3xl mb-16">
				<div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-indigo-500/10 border border-indigo-500/30 text-xs font-bold uppercase tracking-widest text-indigo-400 mb-6">
					<span>Kontakt & Darmowa Wycena</span>
				</div>
				<h1 class="text-4xl sm:text-6xl lg:text-7xl font-black uppercase italic tracking-tighter text-white leading-none mb-8">
					Porozmawiajmy o nowej stronie <br />
					<span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-400">
						i dopływie klientów.
					</span>
				</h1>
				<p class="text-white/60 text-lg leading-relaxed">
					Skonfiguruj darmową wycenę online w kalkulatorze poniżej lub napisz do nas bezpośrednio. Odpowiadamy zwykle w ciągu 2 godzin.
				</p>
			</div>

			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-20">
				<div class="p-8 rounded-[2.5rem] bg-white/[0.02] border border-white/10">
					<div class="text-xs font-bold uppercase tracking-widest text-indigo-400 mb-2">Telefon:</div>
					<a href="tel:+48786429360" class="text-lg font-black text-white italic hover:text-indigo-400 transition-colors">+48 786 429 360</a>
					<div class="text-xs text-white/40 mt-2">Pon - Pt: 8:00 - 18:00</div>
				</div>

				<div class="p-8 rounded-[2.5rem] bg-white/[0.02] border border-white/10">
					<div class="text-xs font-bold uppercase tracking-widest text-indigo-400 mb-2">E-mail:</div>
					<a href="mailto:kontakt@foundly.pl" class="text-lg font-black text-white italic hover:text-indigo-400 transition-colors">kontakt@foundly.pl</a>
					<div class="text-xs text-white/40 mt-2">Napisz w dowolnej chwili</div>
				</div>

				<div class="p-8 rounded-[2.5rem] bg-white/[0.02] border border-white/10">
					<div class="text-xs font-bold uppercase tracking-widest text-indigo-400 mb-2">Start kampanii:</div>
					<div class="text-lg font-black text-white italic">Wersja Startowa 48h</div>
					<div class="text-xs text-white/40 mt-2">Materiały w 2 dni</div>
				</div>

				<div class="p-8 rounded-[2.5rem] bg-white/[0.02] border border-white/10">
					<div class="text-xs font-bold uppercase tracking-widest text-indigo-400 mb-2">Obszar działania:</div>
					<div class="text-lg font-black text-white italic">Cała Polska</div>
					<div class="text-xs text-white/40 mt-2">Obsługa w 100% online</div>
				</div>
			</div>

			<CalculatorWizard client:visible />
			<FAQ />
		</section>
	</main>
	<Footer />
</Layout>
